/// Conditionally dispatch requests to the inner service based on an
/// [asynchronous predicate].
/// 
/// [asynchronous predicate]: AsyncPredicate
#[derive(Clone, Debug)]
pub struct AsyncFilter<T, U> {
 inner: T,
 predicate: U,
}

